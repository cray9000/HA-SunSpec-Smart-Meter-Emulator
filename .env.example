# Copy to .env for standalone Docker usage only.
# Home Assistant Add-on mode uses the Supervisor API and does not need HA_TOKEN here.

# Example: http://192.168.1.20:8123/api
HA_BASE_URL=
HA_TOKEN=
HA_WS_URL=

# Multi-meter mode
METERS_FILE=/config/meters.yaml
CONFIG_RELOAD_INTERVAL_S=3

STATUS_PORT=8080
LOG_LEVEL=INFO
RESYNC_INTERVAL_S=300

# Legacy single-meter fallback (only used when METERS_FILE is unset)
# MODBUS_PORT=502
# MODBUS_BIND_PORT=1502
# MODBUS_UNIT_ID=3
# DEVICE_MODBUS_ADDRESS=241
# DEVICE_MANUFACTURER=Fronius
# DEVICE_MODEL=Smart Meter 63A
# DEVICE_NAME=meter1
# DEVICE_VERSION=3.0.1-0002
# DEVICE_SERIAL=00000002
# ENTITY_MAP_PATH=/config/entity_map_sm1.yaml
# MODBUS_ALIAS_UNIT_IDS=1
# MODBUS_BACKEND_HOST=127.0.0.1
# MODBUS_BACKEND_PORT=1502
# MODBUS_RUN_BACKEND=true
# MODBUS_RAW_RELAY=false
# MODBUS_ENABLE_PROXY=true
# MODBUS_LOG_READS=true
# MODBUS_GATE_ENABLE=true
